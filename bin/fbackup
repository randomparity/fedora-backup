#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
# shellcheck source=../lib/common.sh
source "$REPO_DIR/lib/common.sh"
# shellcheck source=../lib/snapshots.sh
source "$REPO_DIR/lib/snapshots.sh"
# shellcheck source=../lib/manifest.sh
source "$REPO_DIR/lib/manifest.sh"

CONFIG="${FBACKUP_CONFIG:-$REPO_DIR/etc/backup.conf}"
PREUPGRADE_TAG=""
mounted_backup=0
mounted_src=0

usage() {
  cat <<'EOF'
Usage: fbackup [--config PATH] [--dry-run] [--preupgrade] [--full]

Snapshot root+home, send/receive incrementally to the USB target, archive
/boot and /boot/efi, write a manifest, and prune old snapshots.

  --preupgrade  tag this snapshot set "preupgrade-f43" (exempt from pruning)
  --full        force a full send (ignore any common parent)
EOF
}

# list_snaps <dir> <subvol> : basenames of snapshots for a subvol in a directory.
list_snaps() {
  local dir="$1" subvol="$2"
  find "$dir" -maxdepth 1 -name "$subvol.*" -printf '%f\n' 2>/dev/null | sort
}

backup_subvol() {
  local subvol="$1" ts="$2" snapshots_dir="$3" target_base="$4" force_full="$5"
  local name
  if [[ -n "$PREUPGRADE_TAG" ]]; then
    name="$subvol.$PREUPGRADE_TAG.$ts"
  else
    name="$subvol.$ts"
  fi

  fb_snapshot "$SRC_TOPLEVEL_MNT/$subvol" "$snapshots_dir/$name" >&2

  local parent=""
  if [[ "$force_full" != "1" ]]; then
    parent="$(select_parent "$subvol" \
      "$(list_snaps "$snapshots_dir" "$subvol")" \
      "$(list_snaps "$target_base/subvols/$subvol" "$subvol")")"
  fi

  fb_send_receive "$snapshots_dir" "$name" "$parent" "$target_base/subvols/$subvol" >&2
  printf '%s' "$parent"
}

# Helper kept tiny so DRY_RUN handling stays in one place.
run_zstd_to() {
  if [[ "${DRY_RUN:-0}" == "1" ]]; then
    printf '[DRY-RUN] zstd > %s\n' "$1" >&2
    cat >/dev/null
    return 0
  fi
  zstd -q -o "$1"
}

archive_one() {
  local src="$1" out="$2"
  if run tar --xattrs --acls -C "$src" -cpf - . | run_zstd_to "$out"; then
    return 0
  fi
  run rm -f "$out"
  die "boot archive failed for $src (removed partial $out)"
}

archive_boot() {
  local target_base="$1" ts="$2"
  archive_one "$BOOT_MNT" "$target_base/boot/boot.$ts.tar.zst"
  archive_one "$EFI_MNT" "$target_base/boot/efi.$ts.tar.zst"
}

prune_side() {
  local dir="$1" subvol="$2" protect="$3" del
  while IFS= read -r del; do
    [[ -z "$del" ]] && continue
    run btrfs subvolume delete "$dir/$del"
  done < <(prune_candidates "$RETENTION_KEEP" "$(list_snaps "$dir" "$subvol")" "$protect")
}

# cleanup : unmount what we mounted, on success or failure. Idempotent.
cleanup() {
  [[ "$mounted_src" == "1" ]] && { run umount "$SRC_TOPLEVEL_MNT" || true; }
  [[ "$mounted_backup" == "1" ]] && { run umount "$BACKUP_MNT" || true; }
  return 0
}

main() {
  local force_full=0 arg
  for arg in "$@"; do
    case "$arg" in
    --help | -h)
      usage
      return 0
      ;;
    --dry-run) export DRY_RUN=1 ;;
    --preupgrade) PREUPGRADE_TAG="preupgrade-f43" ;;
    --full) force_full=1 ;;
    --config=*) CONFIG="${arg#--config=}" ;;
    esac
  done

  [[ "${SKIP_ROOT_CHECK:-0}" == "1" ]] || require_root
  load_config "$CONFIG"

  local ts snapshots_dir target_base
  ts="$(snap_timestamp)"
  snapshots_dir="$SRC_TOPLEVEL_MNT/$SNAP_DIR"
  target_base="$BACKUP_MNT/$HOSTNAME_TAG"

  run mkdir -p "$SRC_TOPLEVEL_MNT" "$BACKUP_MNT"
  trap cleanup EXIT
  if ! findmnt -rno TARGET "$BACKUP_MNT" >/dev/null 2>&1; then
    run mount "$BACKUP_DEV" "$BACKUP_MNT"
    mounted_backup=1
  fi

  [[ -d "$target_base/subvols" ]] ||
    die "backup target not initialized at $target_base; run fbackup-init first"

  local root_src
  root_src="$(findmnt -no SOURCE / | sed 's/\[.*\]//')"
  if ! findmnt -rno TARGET "$SRC_TOPLEVEL_MNT" >/dev/null 2>&1; then
    run mount -o subvolid=5 "$root_src" "$SRC_TOPLEVEL_MNT"
    mounted_src=1
  fi
  run mkdir -p "$snapshots_dir"

  local subvol parent parents=()
  for subvol in "${SUBVOLS[@]}"; do
    parent="$(backup_subvol "$subvol" "$ts" "$snapshots_dir" "$target_base" "$force_full")"
    parents+=("$subvol=$parent")
  done
  local parent_summary="${parents[*]}"

  archive_boot "$target_base" "$ts"

  local fedora_ver manifest
  fedora_ver="$(
    . /etc/os-release 2>/dev/null || true
    printf '%s' "${VERSION_ID:-unknown}"
  )"
  manifest="$(build_manifest_json "$ts" "$parent_summary" \
    "$fedora_ver" "$HOSTNAME_TAG" \
    "$(cat /etc/fstab 2>/dev/null || true)" \
    "$(btrfs subvolume list "$SRC_TOPLEVEL_MNT" 2>/dev/null || true)" \
    "$(btrfs filesystem show 2>/dev/null || true)" \
    "$(rpm -q kernel 2>/dev/null || true)")"
  if [[ "${DRY_RUN:-0}" == "1" ]]; then
    printf '[DRY-RUN] write manifest.%s.json\n' "$ts" >&2
  else
    printf '%s\n' "$manifest" >"$target_base/manifests/manifest.$ts.json"
  fi

  if [[ -z "$PREUPGRADE_TAG" ]]; then
    local common_parent
    for subvol in "${SUBVOLS[@]}"; do
      common_parent="$(select_parent "$subvol" \
        "$(list_snaps "$snapshots_dir" "$subvol")" \
        "$(list_snaps "$target_base/subvols/$subvol" "$subvol")")"
      prune_side "$snapshots_dir" "$subvol" "$common_parent"
      prune_side "$target_base/subvols/$subvol" "$subvol" "$common_parent"
    done
  fi

  run sync
  log_info "Backup complete: timestamp $ts"
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
