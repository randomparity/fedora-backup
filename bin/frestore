#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
# shellcheck source=../lib/common.sh
source "$REPO_DIR/lib/common.sh"
# shellcheck source=../lib/restore.sh
source "$REPO_DIR/lib/restore.sh"

CONFIG="${FBACKUP_CONFIG:-$REPO_DIR/etc/backup.conf}"
DEST_TOPLEVEL="${DEST_TOPLEVEL:-/mnt/restore-target}"
SNAPSHOT=""
BOOT_DIR=""
EFI_DIR=""

# Populated by load_config; declared here so shellcheck tracks them as globals.
BACKUP_DEV="" BACKUP_MNT="" HOSTNAME_TAG=""
mounted_backup=0

# cleanup : unmount the backup target only if this run mounted it.
cleanup() {
  [[ "$mounted_backup" == "1" ]] && { run umount "$BACKUP_MNT" || true; }
  return 0
}

usage() {
  cat <<'EOF'
Usage: frestore --snapshot <root.TIMESTAMP> [--apply] [--config PATH]
                [--boot-dir DIR] [--efi-dir DIR]

Disaster recovery from the USB target. Run from a Fedora live/rescue
environment. Without --apply this performs a DRY-RUN and changes nothing.

Receives every configured subvolume for the given timestamp onto DEST_TOPLEVEL
(default /mnt/restore-target; override with the DEST_TOPLEVEL env var) and
creates the canonical writable subvolumes.

  --boot-dir DIR  extract boot.<ts>.tar.zst into DIR (mount the RECOVERY disk's
                  /boot there first). Omit to skip and get a printed command.
  --efi-dir DIR   extract efi.<ts>.tar.zst into DIR (the recovery ESP mount).

Guided only (printed): /etc/fstab UUID rewrite and bootloader reinstall, which
depend on the new disk's UUIDs and UEFI layout.
EOF
}

main() {
  export DRY_RUN=1
  while [[ $# -gt 0 ]]; do
    case "$1" in
    --help | -h)
      usage
      return 0
      ;;
    --apply)
      export DRY_RUN=0
      shift
      ;;
    --snapshot)
      SNAPSHOT="${2:-}"
      shift 2
      ;;
    --snapshot=*)
      SNAPSHOT="${1#--snapshot=}"
      shift
      ;;
    --boot-dir)
      BOOT_DIR="${2:-}"
      shift 2
      ;;
    --boot-dir=*)
      BOOT_DIR="${1#--boot-dir=}"
      shift
      ;;
    --efi-dir)
      EFI_DIR="${2:-}"
      shift 2
      ;;
    --efi-dir=*)
      EFI_DIR="${1#--efi-dir=}"
      shift
      ;;
    --config)
      CONFIG="${2:-}"
      shift 2
      ;;
    --config=*)
      CONFIG="${1#--config=}"
      shift
      ;;
    *) die "unknown argument: $1" ;;
    esac
  done

  [[ -n "$SNAPSHOT" ]] || die "missing --snapshot <root.TIMESTAMP>"
  [[ "$SNAPSHOT" == root.* ]] || die "snapshot must be the root snapshot, e.g. root.<TIMESTAMP>"
  [[ "${SKIP_ROOT_CHECK:-0}" == "1" ]] || require_root
  load_config "$CONFIG"

  local base ts subvol snap
  base="$BACKUP_MNT/$HOSTNAME_TAG"
  ts="${SNAPSHOT#root.}"

  run mkdir -p "$BACKUP_MNT" "$DEST_TOPLEVEL"
  trap cleanup EXIT
  if ! findmnt -rno TARGET "$BACKUP_MNT" >/dev/null 2>&1; then
    run mount "$BACKUP_DEV" "$BACKUP_MNT"
    mounted_backup=1
  fi

  for subvol in "${SUBVOLS[@]}"; do
    snap="$subvol.$ts"
    if [[ -e "$DEST_TOPLEVEL/$subvol" ]]; then
      die "destination already has a subvolume named '$subvol' at $DEST_TOPLEVEL; refusing to overwrite (clean the target first)"
    fi
    if [[ -e "$DEST_TOPLEVEL/$snap" ]]; then
      die "destination already has '$snap' at $DEST_TOPLEVEL (leftover from a previous run?); remove it first"
    fi
  done

  for subvol in "${SUBVOLS[@]}"; do
    snap="$subvol.$ts"
    log_info "Receiving $snap onto $DEST_TOPLEVEL"
    restore_receive "$base/subvols/$subvol" "$snap" "$DEST_TOPLEVEL"
    restore_canonicalize "$DEST_TOPLEVEL" "$snap" "$subvol"
  done

  if [[ -n "$BOOT_DIR" ]]; then
    log_info "Extracting /boot into $BOOT_DIR"
    restore_boot "$base/boot/boot.$ts.tar.zst" "$BOOT_DIR"
  else
    log_warn "no --boot-dir: skipping /boot extraction. To restore boot later:"
    printf '  tar --xattrs --acls -xpf %s -C <recovery-boot-mount>\n' \
      "$base/boot/boot.$ts.tar.zst" >&2
  fi

  if [[ -n "$EFI_DIR" ]]; then
    log_info "Extracting /boot/efi into $EFI_DIR"
    restore_boot "$base/boot/efi.$ts.tar.zst" "$EFI_DIR"
  else
    log_warn "no --efi-dir: skipping /boot/efi extraction. To restore later:"
    printf '  tar --xattrs --acls -xpf %s -C <recovery-efi-mount>\n' \
      "$base/boot/efi.$ts.tar.zst" >&2
  fi

  cat >&2 <<EOF

Received subvolumes were snapshotted to canonical names under $DEST_TOPLEVEL.
NEXT (manual, see docs/RUNBOOK.md) — depends on the new disk's UUIDs/UEFI:
  1. Rewrite /etc/fstab UUIDs to the new filesystems (use the manifest).
  2. Reinstall the bootloader and regenerate initramfs:
       grub2-mkconfig -o /boot/grub2/grub.cfg
       (UEFI: ensure the EFI entry points at the new ESP)
EOF
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
